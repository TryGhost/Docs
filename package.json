{
    "name": "@tryghost/docs",
    "private": true,
    "engines": {
        "node": "^24.0.0"
    },
    "scripts": {
        "a11y": "mint a11y",
        "dev": "mint dev",
        "format": "oxfmt .",
        "lint": "oxlint --quiet && oxfmt --check .",
        "lint:fix": "oxlint --fix && oxfmt .",
        "test": "pnpm test:validate && pnpm test:links",
        "test:validate": "mint validate --telemetry=false",
        "test:links": "mint broken-links --check-anchors --check-redirects --check-snippets --telemetry=false"
    },
    "devDependencies": {
        "mint": "4.2.694",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0"
    },
    "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
