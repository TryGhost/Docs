{
    "name": "@tryghost/docs",
    "private": true,
    "engines": {
        "node": "^24.0.0"
    },
    "scripts": {
        "a11y": "mint a11y",
        "dev": "mint dev",
        "format": "oxfmt .",
        "lint": "oxlint --quiet && oxfmt --check .",
        "lint:fix": "oxlint --fix && oxfmt .",
        "test": "pnpm test:validate && pnpm test:links",
        "test:validate": "mint validate --telemetry=false",
        "test:links": "mint broken-links --check-anchors --check-redirects --check-snippets --telemetry=false"
    },
    "devDependencies": {
        "mint": "4.2.694",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0"
    },
    "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
