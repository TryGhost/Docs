{
    "name": "@tryghost/docs",
    "private": true,
    "engines": {
        "node": "^24.0.0"
    },
    "scripts": {
        "a11y": "mint a11y",
        "dev": "mint dev",
        "format": "oxfmt .",
        "lint": "oxlint --quiet && oxfmt --check .",
        "lint:fix": "oxlint --fix && oxfmt .",
        "test": "pnpm test:validate && pnpm test:links",
        "test:validate": "mint validate --telemetry=false",
        "test:links": "mint broken-links --check-anchors --check-redirects --check-snippets --telemetry=false"
    },
    "devDependencies": {
        "mint": "4.2.694",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0"
    },
    "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
