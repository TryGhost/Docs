{
    "name": "@tryghost/docs",
    "private": true,
    "engines": {
        "node": "^24.0.0"
    },
    "scripts": {
        "a11y": "mint a11y",
        "dev": "mint dev",
        "format": "oxfmt .",
        "lint": "oxlint --quiet && oxfmt --check .",
        "lint:fix": "oxlint --fix && oxfmt .",
        "test": "pnpm test:validate && pnpm test:links",
        "test:validate": "mint validate --telemetry=false",
        "test:links": "mint broken-links --check-anchors --check-redirects --check-snippets --telemetry=false"
    },
    "devDependencies": {
        "mint": "4.2.694",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0"
    },
    "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
